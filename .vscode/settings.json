{
  "files.associations": {
    "**/*.json5": "json5"
  },
  "json5.schemaDownload.trustedDomains": {
    "https://docs.renovatebot.com": true
  },
  "yaml.schemaStore.enable": true,
  "yaml.schemas": {
    "kubernetes": "./kubernetes/**/*.yaml"
  },
  "[json5]": {
    "editor.formatOnSave": false
  },
  "[yaml]": {
    "editor.defaultFormatter": "bluebrown.yamlfmt"
  }
}